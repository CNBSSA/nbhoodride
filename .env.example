# PG Ride — environment variables
# Copy to Railway → Variables. Track B (you) sets secrets; Track A code is ready without them.
# Full inventory: docs/TRACK_B_CREDENTIALS.md

# ── Required for deploy ──────────────────────────────────────────────────────
DATABASE_URL=
SESSION_SECRET=

# ── Payments (Track B — before card / top-up live) ───────────────────────────
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# ── AI assistant (Track B — before AI live) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ── Maps: geocoding + driving routes (optional) ──────────────────────────────
# If set, /api/geocode/suggest and /api/route use Mapbox (better US address
# matching + higher-quality driving routes). If unset, they fall back to free
# OpenStreetMap services (Nominatim for addresses, OSRM public demo for routes)
# — no key needed to work, but Mapbox is recommended before real launch volume.
MAPBOX_TOKEN=

# ── Object storage (Track B — before driver doc uploads live) ──────────────────
GCS_BUCKET_NAME=
# GOOGLE_CLOUD_STORAGE_BUCKET=   # alias
# AWS_STORAGE_BUCKET_NAME=       # alias
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
GCS_PRIVATE_PREFIX=pg-ride/private

# ── Email (Track B — before transactional email live) ────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@pgride.app

# ── Push notifications (optional) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
VITE_VAPID_PUBLIC_KEY=

# ── SMS / SOS (optional) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Point Twilio inbound webhook to POST /api/sms/inbound (Phase E4)

# ── Tax compliance path (Phase E2 — MASTER_PLAN §15) ─────────────────────────
# path_a_stripe | path_b_tax1099 | path_c_manual
TAX_COMPLIANCE_PATH=path_b_tax1099

# ── Public URLs ──────────────────────────────────────────────────────────────
PUBLIC_APP_URL=
APP_URL=
# CAPACITOR_SERVER_URL=           # Native app WebView URL (defaults to PUBLIC_APP_URL / Railway)
# CAPACITOR_USE_LOCAL=true        # Dev only — bundle assets instead of remote URL
# RAILWAY_PUBLIC_DOMAIN=          # auto-set on Railway
# ALLOWED_ORIGINS=                # comma-separated CORS origins

# ── One-time bootstrap ─────────────────────────────────────────────────────────
SUPER_ADMIN_SETUP_TOKEN=
SUPER_ADMIN_EMAIL=

# ── Background checks (optional) ─────────────────────────────────────────────
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=

# ── Transit (Phase F — WMATA developer API key) ─────────────────────────────
WMATA_API_KEY=

# ── Dev / test only (never in production) ────────────────────────────────────
# ENABLE_TEST_LOGIN=true
# TEST_PASSWORD=
# TEST_USER_IDS=
