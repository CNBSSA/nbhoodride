# PGRide environment variables
# Copy this file to .env and fill in values for local dev only.
# In production, set these in Railway → Variables (never commit them).

# === Required for app to start ===
NODE_ENV=production
DATABASE_URL=postgresql://user:pass@host:5432/dbname     # Railway Postgres plugin auto-sets this
SESSION_SECRET=                                          # 64-char random hex; rotate periodically

# === Required for admin onboarding ===
SUPER_ADMIN_SETUP_TOKEN=                                 # 64-char random hex; secret URL token

# === Required for email (registration, password reset, ride notifications) ===
GMAIL_USER=thrynovaproductions@gmail.com
GMAIL_APP_PASSWORD=                                      # Gmail app password (NOT account password)
GMAIL_FROM=thrynovaproductions@gmail.com

# === Required for web push notifications ===
# Generate locally with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:thrynovaproductions@gmail.com
VITE_VAPID_PUBLIC_KEY=                                   # Same as VAPID_PUBLIC_KEY (exposed to client)

# === Required for AI chat features ===
ANTHROPIC_API_KEY=                                       # console.anthropic.com → API Keys

# === Optional — Stripe payments (skip for initial launch) ===
STRIPE_SECRET_KEY=                                       # sk_test_... or sk_live_...; powers card storage, top-ups, and ride shortfall charges
VITE_STRIPE_PUBLIC_KEY=                                  # pk_test_... or pk_live_... — must match the secret key's mode
STRIPE_WEBHOOK_SECRET=                                   # whsec_...; from `stripe listen` or Stripe Dashboard → Webhooks. Required by /api/webhooks/stripe

# === Optional — Google Cloud Storage for driver documents ===
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=                          # path to service-account JSON
GOOGLE_CLOUD_STORAGE_BUCKET=

# === Auto-set by Railway (do not set manually) ===
# RAILWAY_PUBLIC_DOMAIN=<your-app>.up.railway.app
# PORT=<auto>
