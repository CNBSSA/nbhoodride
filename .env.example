# PG Ride — environment variables
# Copy to Railway → Variables. Track B (you) sets secrets; Track A code is ready without them.

# ── Required for deploy ──────────────────────────────────────────────────────
DATABASE_URL=
SESSION_SECRET=

# ── Payments (Track B — before card / top-up live) ───────────────────────────
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLIC_KEY=

# ── AI assistant (Track B — before AI live) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ── Object storage (Track B — before driver doc uploads live) ──────────────────
# Agent implements GCS wiring; you provide bucket + credentials.
GCS_BUCKET_NAME=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json  # or Railway GCS integration
GCS_PRIVATE_PREFIX=pg-ride/private

# ── Push notifications (optional) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
VITE_VAPID_PUBLIC_KEY=

# ── SMS / SOS (optional) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── One-time bootstrap ─────────────────────────────────────────────────────────
SUPER_ADMIN_SETUP_TOKEN=

# ── Optional integrations ──────────────────────────────────────────────────────
CHECKR_API_KEY=
CHECKR_WEBHOOK_SECRET=
